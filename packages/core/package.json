{
  "name": "@fhirbridge/core",
  "version": "0.1.0",
  "description": "FHIR R4 engine, validators, and de-identification for FHIRBridge",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@fhirbridge/types": "workspace:*",
    "csv-parse": "^6.2.1",
    "exceljs": "^4.4.0",
    "fhir-kit-client": "^1.9.2",
    "iconv-lite": "^0.6.3",
    "openai": "^6.45.0",
    "pdfkit": "^0.18.0",
    "unzipper": "^0.12.5",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@types/pdfkit": "^0.17.6",
    "@types/unzipper": "^0.10.11",
    "@types/uuid": "^11.0.0",
    "typescript": "*",
    "vitest": "*"
  },
  "type": "module"
}
