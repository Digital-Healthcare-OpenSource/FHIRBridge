{
  "name": "fhirbridge",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, self-hosted FHIR R4 patient data portability tool with optional AI summaries. Hospitals and clinics pull and run it on their own infrastructure.",
  "license": "MIT",
  "author": "tranhoangtu-it",
  "homepage": "https://github.com/tranhoangtu-it/FHIRBridge#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tranhoangtu-it/FHIRBridge.git"
  },
  "bugs": {
    "url": "https://github.com/tranhoangtu-it/FHIRBridge/issues"
  },
  "keywords": [
    "fhir",
    "fhir-r4",
    "healthcare",
    "patient-data",
    "ips",
    "interoperability",
    "self-hosted",
    "open-source",
    "deidentification",
    "ai-summary"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\" --ignore-path .gitignore",
    "prepare": "husky",
    "test:integration": "vitest run --project integration",
    "test:e2e:cli": "vitest run --project cli-e2e",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:security": "vitest run --config vitest.security.config.ts",
    "test:a11y": "playwright test --grep @a11y",
    "test:perf": "vitest run --config vitest.perf.config.ts",
    "test:all": "pnpm test && pnpm test:integration && pnpm test:e2e && pnpm test:security && pnpm test:perf"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.61.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "dotenv": "^17.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "husky": "^9.1.6",
    "jsonwebtoken": "^9.0.3",
    "lint-staged": "^15.2.10",
    "prettier": "^3.9.5",
    "turbo": "^2.9.14",
    "typescript": "^5.5.4",
    "vitest": "^3.2.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.11.0",
  "pnpm": {
    "overrides": {
      "fast-jwt": "^6.2.4",
      "cross-spawn@<7.0.5": "7.0.5",
      "form-data@>=4 <4.0.6": "4.0.6",
      "glob@>=10 <10.5.0": "10.5.0",
      "minimatch@>=9 <9.0.7": "9.0.7",
      "fast-uri@<3.1.4": "3.1.4",
      "fast-uri@>=4 <4.1.1": "4.1.1",
      "brace-expansion@<1.1.16": "1.1.16",
      "brace-expansion@>=2 <2.1.2": "2.1.2",
      "brace-expansion@>=3 <5.0.7": "5.0.7",
      "tmp@<0.2.7": "0.2.7",
      "ws@>=8 <8.21.0": "8.21.0",
      "react-router@>=7 <7.15.0": "7.15.0",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4 <4.0.4": "4.0.4",
      "uuid@<14": "14.0.0",
      "vite@<6": "6.4.2"
    }
  }
}
