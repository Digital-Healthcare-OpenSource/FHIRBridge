.env
.env.local
.env.*.local
!.env.example

# Test coverage
coverage/
.nyc_output/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/settings.json
*.swp
*.swo

# Turbo
.turbo/

# Temp
tmp/
temp/
*.tmp

# Synthea generated data (large files)
tests/fixtures/synthea/*.json
tests/fixtures/synthea/*.ndjson
!tests/fixtures/synthea/.gitkeep

# Docker volumes
docker/volumes/

# Claude sessions + project-private docs/plans (keep local-only, never push).
# docs/* (not docs/) so operator-facing docs/operations/ — which the README
# links to — can be re-included and shipped publicly.
.claude/
CLAUDE.md
docs/*
!docs/operations/
plans/

# Lock file debug
pnpm-debug.yaml

# Generated fixtures (recreated by scripts)
tests/fixtures/excel/generate-fixture.cjs

# Playwright E2E test artifacts
tests/e2e/test-results/
tests/e2e/screenshots/
tests/perf/lighthouse-reports/
playwright-report/
blob-report/
